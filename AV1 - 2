let nota1, nota2, nota3, notaParcial, notaFinal, frequencia;

nota1 = Number(prompt("Qual sua nota na AV1? "));
nota2 = Number(prompt("Qual sua nota na AV2? "));
notaParcial = (nota1 + nota2) / 2


if (notaParcial >= 4) {
    nota3 = Number(prompt("Qual sua nota na Av3? "));
    notaFinal = (notaParcial + nota3) / 2
    if (notaFinal >= 5) {
        frequencia = Number(prompt("Qual sua frequência? (somente o número) "))
        frequencia = frequencia / 10
        
        if (frequencia >= 0.75) {
            console.log("Você for aprovado :)")
        } else {
            console.log("Você for reprovado na nota final.")
        }
    }
    
} else {
    console.log("Você foi reprovado na nota parcial.")
}
