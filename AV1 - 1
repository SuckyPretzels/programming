let age, contribution

age = Number(prompt("Qual sua idade? "))

if (age >= 65) {
    console.log("Você pode se aposentar :)");
} else if (age < 60) {
    console.log("Você não pode se aposentar :(")
} else {
    contribution = Number(prompt("Qual seu tempo de contribuição? "))

    if (age >= 60 && contribution >= 30) {
        console.log("Você pode se aposentar :)");
    } else {
        console.log("Você não pode se aposentar :(")
    }
}

